pub(super) fn check_xattr_namespace(namespace: XattrNamespace, ctx: &Context) -> Result<()> {
    if namespace != XattrNamespace::Trusted {
        return Ok(());
    }

    if !ctx
        .posix_thread
        .credentials()
        .permitted_capset()
        .contains(CapSet::SYS_ADMIN)
    {

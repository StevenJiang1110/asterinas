   436	    /// Applies previously computed capability sets for `execve()`.
   437	    pub(super) fn update_capsets_for_exec(&self, capsets: ExecCapSets) {
   438	        self.set_permitted_capset(capsets.permitted);
   439	        self.set_effective_capset(capsets.effective);
   440	    }
   441	
   442	    fn calculate_capsets_for_exec(
   443	        &self,
   444	        file_capabilities: Option<FileCapabilities>,
   445	        exec_euid: Uid,
   446	    ) -> ExecCapSets {
   447	        // Reference: The "Transformation of capabilities during execve()" section and
   448	        // the "Capabilities and execution of programs by root" section in
   449	        // <https://man7.org/linux/man-pages/man7/capabilities.7.html>.
   450	        let no_root = self.securebits().no_root();
   451	        let has_file_capabilities = file_capabilities.is_some();
   452	
   453	        // Linux treats root specially when the executable has no file capabilities, or when the
   454	        // real UID is root. The setuid-root + file-capability exception is handled by excluding
   455	        // the `euid == 0` fast path when a file capability xattr is present.
   456	        let grant_root_file_sets =
   457	            !no_root && (self.ruid().is_root() || (!has_file_capabilities && exec_euid.is_root()));
   458	
   459	        let file_permitted = if grant_root_file_sets {
   460	            CapSet::all()
   461	        } else {
   462	            file_capabilities.map_or(CapSet::empty(), FileCapabilities::permitted)
   463	        };
   464	        let file_inheritable = if grant_root_file_sets {
   465	            CapSet::all()
   466	        } else {
   467	            file_capabilities.map_or(CapSet::empty(), FileCapabilities::inheritable)
   468	        };
   469	
   470	        let file_effective = if (!no_root && exec_euid.is_root())
   471	            || file_capabilities.is_some_and(FileCapabilities::has_effective_flag)
   472	        {
   473	            CapSet::all()
   474	        } else {
   475	            CapSet::empty()
   476	        };
   477	
   478	        let new_permitted = (self.inheritable_capset() & file_inheritable)
   479	            | (file_permitted & self.bounding_capset())
   480	            | AMBIENT_CAPSET;
   481	
   482	        let new_effective = (file_effective & new_permitted) | (!file_effective & AMBIENT_CAPSET);
   483	
   484	        ExecCapSets {
   485	            permitted: new_permitted,
   486	            effective: new_effective,
   487	        }
   488	    }

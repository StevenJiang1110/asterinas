   410	    /// Computes and validates the capability sets for `execve()`.
   411	    pub(super) fn prepare_capsets_for_exec(
   412	        &self,
   413	        file_capabilities: Option<FileCapabilities>,
   414	        exec_euid: Uid,
   415	    ) -> Result<ExecCapSets> {
   416	        let capsets = self.calculate_capsets_for_exec(file_capabilities, exec_euid);
   417	
   418	        // Linux performs this safety check only for capability-dumb binaries, which use the
   419	        // effective flag to request that every permitted file capability becomes effective.
   420	        let Some(file_capabilities) =
   421	            file_capabilities.filter(|file_capabilities| file_capabilities.has_effective_flag())
   422	        else {
   423	            return Ok(capsets);
   424	        };
   425	
   426	        if !capsets.permitted.contains(file_capabilities.permitted()) {
   427	            return_errno_with_message!(
   428	                Errno::EPERM,
   429	                "the executable requests file capabilities outside the current bounding set"
   430	            );
   431	        }
   432	
   433	        Ok(capsets)
   434	    }

    /// copying bytes to userspace.
    pub(super) fn list_xattr(
        &self,
        namespace: XattrNamespace,
        list_writer: &mut VmWriter,
    ) -> Result<usize> {
        self.cache.write().list_entries(namespace, list_writer)
    }


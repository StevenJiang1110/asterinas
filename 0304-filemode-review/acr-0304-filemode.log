    26	const XATTR_CAPS_SZ_1: usize = 3 * size_of::<u32>();
    27	const XATTR_CAPS_SZ_2: usize = 5 * size_of::<u32>();
    28	const XATTR_CAPS_SZ_3: usize = 6 * size_of::<u32>();
    29	
    30	/// File capabilities loaded from the `security.capability` xattr.
    31	#[derive(Clone, Copy, Debug)]
    32	pub(in crate::process) struct FileCapabilities {
    33	    permitted: CapSet,
    34	    inheritable: CapSet,
    35	    has_effective_flag: bool,
    36	    root_uid: Option<Uid>,
    37	}
    38	
    39	impl FileCapabilities {
    40	    /// Reads file capabilities from an inode's `security.capability` xattr.
    41	    pub(in crate::process) fn read_from_inode(inode: &Arc<dyn Inode>) -> Result<Option<Self>> {
    42	        let mut raw_value = [0u8; XATTR_CAPS_SZ_3];
    43	        let mut value_writer = VmWriter::from(raw_value.as_mut_slice()).to_fallible();
    44	        let xattr_name =
    45	            xattr::XattrName::try_from_full_name(xattr::SECURITY_CAPABILITY_XATTR_NAME).unwrap();
    46	        let value_len = match inode.get_xattr(xattr_name, &mut value_writer) {
    47	            Ok(value_len) => value_len,
    48	            Err(error) if matches!(error.error(), Errno::ENODATA | Errno::EOPNOTSUPP) => {
    49	                return Ok(None);
    50	            }
    51	            Err(error) => return Err(error),
    52	        };
    53	
    54	        Self::parse(&raw_value[..value_len]).map(Some)
    55	    }
    56	
    57	    pub(in crate::process) const fn permitted(self) -> CapSet {
    58	        self.permitted
    59	    }
    60	
    61	    pub(in crate::process) const fn inheritable(self) -> CapSet {
    62	        self.inheritable
    63	    }
    64	
    65	    pub(in crate::process) const fn has_effective_flag(self) -> bool {
    66	        self.has_effective_flag
    67	    }
    68	
    69	    pub(in crate::process) fn applies_to_root_uid(self, root_uid: Uid) -> bool {
    70	        self.root_uid
    71	            .is_none_or(|stored_root_uid| stored_root_uid == root_uid)
    72	    }
    73	
    74	    fn parse(raw_value: &[u8]) -> Result<Self> {
    75	        let magic_etc = read_u32_le(raw_value, 0)?;
    76	        let (revision, flags) = parse_revision_and_flags(magic_etc)?;
    77	
    78	        let (expected_len, permitted, inheritable, root_uid) = match revision {
    79	            VfsCapRevision::V1 => {
    80	                let Ok(permitted) = CapSet::try_from_lo_hi(read_u32_le(raw_value, 1)?, 0) else {
    81	                    return_errno_with_message!(
    82	                        Errno::EINVAL,
    83	                        "file capabilities contain unsupported capability bits"
    84	                    );
    85	                };
    86	                let Ok(inheritable) = CapSet::try_from_lo_hi(read_u32_le(raw_value, 2)?, 0) else {
    87	                    return_errno_with_message!(
    88	                        Errno::EINVAL,
    89	                        "file capabilities contain unsupported capability bits"
    90	                    );
    91	                };
    92	                (XATTR_CAPS_SZ_1, permitted, inheritable, None)
    93	            }
    94	            VfsCapRevision::V2 => {
    95	                let Ok(permitted) =
    96	                    CapSet::try_from_lo_hi(read_u32_le(raw_value, 1)?, read_u32_le(raw_value, 3)?)
    97	                else {
    98	                    return_errno_with_message!(
    99	                        Errno::EINVAL,
   100	                        "file capabilities contain unsupported capability bits"
   101	                    );
   102	                };
   103	                let Ok(inheritable) =
   104	                    CapSet::try_from_lo_hi(read_u32_le(raw_value, 2)?, read_u32_le(raw_value, 4)?)
   105	                else {
   106	                    return_errno_with_message!(
   107	                        Errno::EINVAL,
   108	                        "file capabilities contain unsupported capability bits"
   109	                    );
   110	                };
   111	                (XATTR_CAPS_SZ_2, permitted, inheritable, None)
   112	            }
   113	            VfsCapRevision::V3 => {
   114	                let Ok(permitted) =
   115	                    CapSet::try_from_lo_hi(read_u32_le(raw_value, 1)?, read_u32_le(raw_value, 3)?)
   116	                else {
   117	                    return_errno_with_message!(
   118	                        Errno::EINVAL,
   119	                        "file capabilities contain unsupported capability bits"
   120	                    );
   121	                };
   122	                let Ok(inheritable) =
   123	                    CapSet::try_from_lo_hi(read_u32_le(raw_value, 2)?, read_u32_le(raw_value, 4)?)
   124	                else {
   125	                    return_errno_with_message!(
   126	                        Errno::EINVAL,
   127	                        "file capabilities contain unsupported capability bits"
   128	                    );
   129	                };
   130	                (
   131	                    XATTR_CAPS_SZ_3,
   132	                    permitted,
   133	                    inheritable,
   134	                    Some(Uid::new(read_u32_le(raw_value, 5)?)),
   135	                )
   136	            }
   137	        };
   138	
   139	        if raw_value.len() != expected_len {
   140	            return_errno_with_message!(
   141	                Errno::EINVAL,
   142	                "file capability xattr length does not match its revision"
   143	            );
   144	        }
   145	
   146	        Ok(Self {
   147	            permitted,
   148	            inheritable,
   149	            has_effective_flag: flags.contains(VfsCapFlags::EFFECTIVE),
   150	            root_uid,
   151	        })
   152	    }
   153	}
   154	
   155	fn parse_revision_and_flags(magic_etc: u32) -> Result<(VfsCapRevision, VfsCapFlags)> {
   156	    let revision_bits = magic_etc & VFS_CAP_REVISION_MASK;
   157	    let Ok(revision) = VfsCapRevision::try_from(revision_bits) else {
   158	        return_errno_with_message!(
   159	            Errno::EINVAL,
   160	            "file capabilities use an unsupported xattr revision"
   161	        );
   162	    };
   163	
   164	    let flags_bits = magic_etc & VFS_CAP_FLAGS_MASK;
   165	    let Some(flags) = VfsCapFlags::from_bits(flags_bits) else {
   166	        return_errno_with_message!(
   167	            Errno::EINVAL,
   168	            "file capabilities contain unsupported flag bits"
   169	        );
   170	    };
   171	
   172	    Ok((revision, flags))
   173	}
   174	
   175	fn read_u32_le(bytes: &[u8], word_index: usize) -> Result<u32> {
   176	    let start = word_index * size_of::<u32>();
   177	    let end = start + size_of::<u32>();
   178	    let Some(word_bytes) = bytes.get(start..end) else {
   179	        return_errno_with_message!(Errno::EINVAL, "file capability xattr is truncated");
   180	    };
   181	
   182	    let mut word = [0u8; size_of::<u32>()];
   183	    word.copy_from_slice(word_bytes);
   184	    Ok(u32::from_le_bytes(word))
   185	}



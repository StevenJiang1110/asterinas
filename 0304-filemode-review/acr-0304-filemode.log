   144	        let should_set_suid = ruid.is_some() || euid.is_some_and(|euid| euid != self.ruid());
   145	        let suid = if should_set_suid {
   146	            Some(euid.unwrap_or_else(|| self.euid()))
   147	        } else {
   148	            None
   149	        };

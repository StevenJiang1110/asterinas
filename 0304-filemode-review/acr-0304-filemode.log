    if uid < 0 {
        return_errno_with_message!(Errno::EINVAL, "UIDs cannot be negative");
    }

    let uid = Uid::new(uid.cast_unsigned());
    debug!("uid = {:?}", uid);

    let credentials = ctx.credentials_mut();
    credentials.set_uid(uid)?;

    Ok(SyscallReturn::Return(0))
}


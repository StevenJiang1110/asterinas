# Bash fragment sourced by the Kata helper scripts.
#
# Override these values either by setting environment variables before invoking
# the scripts or by pointing `KATA_CONFIG_FILE` at another Bash fragment.

: "${CRICTL_VERSION:=v1.29.0}"
: "${KATA_ASTERINAS_KERNEL_PATH:=}"
: "${KATA_CGROUP_NAMESPACE:=private}"
: "${KATA_CGROUP_PARENT:=/kata-ci}"
: "${KATA_INSTALL_CRICTL:=0}"
: "${KATA_PASSES:=1}"
: "${KATA_VERSION:=3.28.0}"
: "${NERDCTL_VERSION:=v2.2.2}"
: "${PAUSE_IMAGE:=registry.k8s.io/pause:3.10}"

if [ "${KATA_STATIC_TARBALL_URL+x}" != x ]; then
  KATA_STATIC_TARBALL_URL="https://github.com/jjf-dev/kata-containers/releases/download/3.28.0-20260414-asterinas/kata-static-3.28.0-asterinas-amd64.tar.zst"
fi

: "${KATA_PAYLOAD_IMAGE:=quay.io/kata-containers/kata-deploy:${KATA_VERSION}}"

: "${CONTAINERD_ADDRESS:=/run/containerd/containerd.sock}"
: "${KATA_NERDCTL_RUNTIME:=io.containerd.kata.v2}"
: "${KATA_SNAPSHOTTER:=native}"

: "${KATA_TEST_NAME:=release-check}"
: "${KATA_TEST_IMAGE:=quay.io/libpod/alpine:latest}"
: "${KATA_TEST_COMMAND:=cat /etc/alpine-release}"
: "${KATA_TEST_COMMAND_SHELL:=/bin/sh}"
: "${KATA_TEST_NET:=none}"
: "${KATA_TEST_PULL_IMAGE:=1}"
: "${KATA_TEST_EXPECT_OUTPUT_REGEX:=^[0-9]+\.[0-9]+(\.|$)}"

if [ "${KATA_ALPINE_IMAGE+x}" = x ] && [ "${KATA_TEST_IMAGE+x}" != x ]; then
  KATA_TEST_IMAGE="${KATA_ALPINE_IMAGE}"
fi

if [ "${KATA_ALPINE_RELEASE_REGEX+x}" = x ] && [ "${KATA_TEST_EXPECT_OUTPUT_REGEX+x}" != x ]; then
  KATA_TEST_EXPECT_OUTPUT_REGEX="${KATA_ALPINE_RELEASE_REGEX}"
fi

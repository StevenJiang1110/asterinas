   385	        }
   386	
   387	        if self.effective_capset().contains(CapSet::SETGID) {
   388	            self.set_fsgid_unchecked(fsgid);
   389	            return Ok(old_fsgid);
   390	        }
   391	
   392	        if fsgid != self.rgid() && fsgid != self.egid() && fsgid != self.sgid() {
   393	            // The new filesystem GID is not one of the associated GIDs.
   394	            return Err(old_fsgid);
   395	        }
   396	
   397	        self.set_fsgid_unchecked(fsgid);
   398	
   399	        Ok(old_fsgid)
   400	    }
   401	
   402	    pub(super) fn set_egid(&self, egid: Gid) {
   403	        self.set_resgid_unchecked(None, Some(egid), None);
   404	    }
   405	
   406	    pub(super) fn set_sgid(&self, sgid: Gid) {
   407	        self.set_resgid_unchecked(None, None, Some(sgid));
   408	    }
   409	
   410	    /// Computes and validates the capability sets for `execve()`.
   411	    pub(super) fn prepare_capsets_for_exec(
   412	        &self,
   413	        file_capabilities: Option<FileCapabilities>,
   414	        exec_euid: Uid,
   415	    ) -> Result<ExecCapSets> {
   416	        let capsets = self.calculate_capsets_for_exec(file_capabilities, exec_euid);
   417	
   418	        // Linux performs this safety check only for capability-dumb binaries, which use the
   419	        // effective flag to request that every permitted file capability becomes effective.
   420	        let Some(file_capabilities) =
   421	            file_capabilities.filter(|file_capabilities| file_capabilities.has_effective_flag())
   422	        else {
   423	            return Ok(capsets);
   424	        };
   425	
   426	        if !capsets.permitted.contains(file_capabilities.permitted()) {
   427	            return_errno_with_message!(
   428	                Errno::EPERM,
   429	                "the executable requests file capabilities outside the current bounding set"
   430	            );
   431	        }
   432	
   433	        Ok(capsets)
   434	    }
   435	
   436	    /// Applies previously computed capability sets for `execve()`.
   437	    pub(super) fn update_capsets_for_exec(&self, capsets: ExecCapSets) {
   438	        self.set_permitted_capset(capsets.permitted);
   439	        self.set_effective_capset(capsets.effective);
   440	    }
   441	
   442	    fn calculate_capsets_for_exec(
   443	        &self,
   444	        file_capabilities: Option<FileCapabilities>,
   445	        exec_euid: Uid,
   446	    ) -> ExecCapSets {
   447	        // Reference: The "Transformation of capabilities during execve()" section and
   448	        // the "Capabilities and execution of programs by root" section in
   449	        // <https://man7.org/linux/man-pages/man7/capabilities.7.html>.
   450	        let no_root = self.securebits().no_root();
   451	        let has_file_capabilities = file_capabilities.is_some();
   452	
   453	        // Linux treats root specially when the executable has no file capabilities, or when the
   454	        // real UID is root. The setuid-root + file-capability exception is handled by excluding
   455	        // the `euid == 0` fast path when a file capability xattr is present.
   456	        let grant_root_file_sets =
   457	            !no_root && (self.ruid().is_root() || (!has_file_capabilities && exec_euid.is_root()));
   458	
   459	        let file_permitted = if grant_root_file_sets {
   460	            CapSet::all()
   461	        } else {
   462	            file_capabilities.map_or(CapSet::empty(), FileCapabilities::permitted)
   463	        };
   464	        let file_inheritable = if grant_root_file_sets {
   465	            CapSet::all()
   466	        } else {
   467	            file_capabilities.map_or(CapSet::empty(), FileCapabilities::inheritable)
   468	        };
   469	
   470	        let file_effective = if (!no_root && exec_euid.is_root())
   471	            || file_capabilities.is_some_and(FileCapabilities::has_effective_flag)
   472	        {
   473	            CapSet::all()
   474	        } else {
   475	            CapSet::empty()
   476	        };
   477	
   478	        let new_permitted = (self.inheritable_capset() & file_inheritable)
   479	            | (file_permitted & self.bounding_capset())
   480	            | AMBIENT_CAPSET;
   481	
   482	        let new_effective = (file_effective & new_permitted) | (!file_effective & AMBIENT_CAPSET);
   483	
   484	        ExecCapSets {
   485	            permitted: new_permitted,
   486	            effective: new_effective,
   487	        }
   488	    }
   489	
   490	    // For `setregid`, the real GID can *NOT* be set to the old saved-set GID,
   491	    // For `setresgid`, the real GID can be set to the old saved-set GID.
   492	    fn check_gid_perm(
   493	        &self,
   494	        rgid: Option<&Gid>,
   495	        egid: Option<&Gid>,
   496	        sgid: Option<&Gid>,
   497	        rgid_may_be_old_sgid: bool,
   498	    ) -> Result<()> {
   499	        if self.effective_capset().contains(CapSet::SETGID) {
   500	            return Ok(());
   501	        }
   502	
   503	        if let Some(rgid) = rgid
   504	            && *rgid != self.rgid()
   505	            && *rgid != self.egid()
   506	            && (!rgid_may_be_old_sgid || *rgid != self.sgid())
   507	        {
   508	            return_errno_with_message!(
   509	                Errno::EPERM,
   510	                "the new real GID is not one of the associated GIDs"
   511	            );
   512	        }
   513	
   514	        if let Some(egid) = egid
   515	            && *egid != self.rgid()
   516	            && *egid != self.egid()
   517	            && *egid != self.sgid()
   518	        {
   519	            return_errno_with_message!(
   520	                Errno::EPERM,
   521	                "the new effective GID is not one of the associated GIDs"
   522	            )
   523	        }
   524	
   525	        if let Some(sgid) = sgid
   526	            && *sgid != self.rgid()
   527	            && *sgid != self.egid()
   528	            && *sgid != self.sgid()
   529	        {
   530	            return_errno_with_message!(
   531	                Errno::EPERM,
   532	                "the new saved-set GID is not one of the associated GIDs"
   533	            )
   534	        }
   535	
   536	        Ok(())
   537	    }
   538	
   539	    fn set_resgid_unchecked(&self, rgid: Option<Gid>, egid: Option<Gid>, sgid: Option<Gid>) {
   540	        if let Some(rgid) = rgid {
   541	            self.rgid.store(rgid, Ordering::Relaxed);
   542	        }
   543	
   544	        if let Some(egid) = egid {
   545	            self.egid.store(egid, Ordering::Relaxed);
   546	        }
   547	
   548	        if let Some(sgid) = sgid {
   549	            self.sgid.store(sgid, Ordering::Relaxed);
   550	        }
   551	
   552	        self.set_fsgid_unchecked(self.egid());
   553	    }
   554	
   555	    fn set_fsgid_unchecked(&self, fsuid: Gid) {
   556	        self.fsgid.store(fsuid, Ordering::Relaxed);
   557	    }

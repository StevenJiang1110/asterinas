   606	
   607	    pub(super) fn drop_bounding_capability(&self, capability: CapSet) -> Result<()> {
   608	        if !self.effective_capset().contains(CapSet::SETPCAP) {
   609	            return_errno_with_message!(
   610	                Errno::EPERM,
   611	                "only threads with CAP_SETPCAP can drop capabilities from the bounding set"
   612	            );
   613	        }
   614	
   615	        let new_bounding_capset = self.bounding_capset() - capability;
   616	        self.set_bounding_capset(new_bounding_capset);
   617	        Ok(())
   618	    }
   619	
   620	    pub(super) fn keep_capabilities(&self) -> bool {
   621	        self.securebits.load(Ordering::Relaxed).keep_capabilities()
   622	    }
   623	
   624	    pub(super) fn set_keep_capabilities(&self, keep_capabilities: bool) -> Result<()> {
   625	        let current_bits = self.securebits();
   626	        let stored_bits = if !keep_capabilities {
   627	            current_bits - SecureBits::KEEP_CAPS
   628	        } else {
   629	            current_bits | SecureBits::KEEP_CAPS
   630	        };
   631	
   632	        self.securebits.try_store(stored_bits, Ordering::Relaxed)
   633	    }
   634	
   635	    //  ******* Secure Bits methods *******
   636	
   637	    pub(super) fn securebits(&self) -> SecureBits {
   638	        self.securebits.load(Ordering::Relaxed)
   639	    }
   640	
   641	    pub(super) fn set_securebits(&self, securebits: SecureBits) -> Result<()> {
   642	        if !self.effective_capset().contains(CapSet::SETPCAP) {
   643	            return_errno_with_message!(
   644	                Errno::EPERM,
   645	                "only threads with CAP_SETPCAP can change secure bits"
   646	            );
   647	        }
   648	
   649	        self.securebits.try_store(securebits, Ordering::Relaxed)
   650	    }
   651	}

   197	
   198	    // For `setreuid`, the real UID can *NOT* be set to the old saved-set user ID,
   199	    // For `setresuid`, the real UID can be set to the old saved-set user ID.
   200	    fn check_uid_perm(
   201	        &self,
   202	        ruid: Option<&Uid>,
   203	        euid: Option<&Uid>,
   204	        suid: Option<&Uid>,
   205	        ruid_may_be_old_suid: bool,
   206	    ) -> Result<()> {
   207	        if self.effective_capset().contains(CapSet::SETUID) {
   208	            return Ok(());
   209	        }
   210	
   211	        if let Some(ruid) = ruid
   212	            && *ruid != self.ruid()
   213	            && *ruid != self.euid()
   214	            && (!ruid_may_be_old_suid || *ruid != self.suid())
   215	        {
   216	            return_errno_with_message!(
   217	                Errno::EPERM,
   218	                "the new real UID is not one of the associated UIDs"
   219	            );
   220	        }
   221	
   222	        if let Some(euid) = euid
   223	            && *euid != self.ruid()
   224	            && *euid != self.euid()
   225	            && *euid != self.suid()
   226	        {
   227	            return_errno_with_message!(
   228	                Errno::EPERM,
   229	                "the new effective UID is not one of the associated UIDs"
   230	            )
   231	        }
   232	
   233	        if let Some(suid) = suid
   234	            && *suid != self.ruid()
   235	            && *suid != self.euid()
   236	            && *suid != self.suid()
   237	        {
   238	            return_errno_with_message!(
   239	                Errno::EPERM,
   240	                "the new saved-set UID is not one of the associated UIDs"
   241	            )
   242	        }
   243	
   244	        Ok(())
   245	    }
   246	
   247	    fn set_resuid_unchecked(&self, ruid: Option<Uid>, euid: Option<Uid>, suid: Option<Uid>) {
   248	        let old_ruid = self.ruid();
   249	        let old_euid = self.euid();
   250	        let old_suid = self.suid();
   251	
   252	        let new_ruid = if let Some(ruid) = ruid {
   253	            self.ruid.store(ruid, Ordering::Relaxed);
   254	            ruid
   255	        } else {
   256	            old_ruid
   257	        };
   258	
   259	        let new_euid = if let Some(euid) = euid {
   260	            self.euid.store(euid, Ordering::Relaxed);
   261	            euid
   262	        } else {
   263	            old_euid
   264	        };
   265	
   266	        let new_suid = if let Some(suid) = suid {
   267	            self.suid.store(suid, Ordering::Relaxed);
   268	            suid
   269	        } else {
   270	            old_suid
   271	        };
   272	
   273	        self.set_fsuid_unchecked(new_euid);
   274	
   275	        // If the `SECBIT_NO_SETUID_FIXUP` bit is set, do not adjust capabilities.
   276	        // Reference: The "SECBIT_NO_SETUID_FIXUP" section in
   277	        // <https://man7.org/linux/man-pages/man7/capabilities.7.html>.
   278	        if self.securebits().no_setuid_fixup() {
   279	            return;
   280	        }
   281	
   282	        // Begin to adjust capabilities.
   283	        // Reference: The "Effect of user ID changes on capabilities" section in
   284	        // <https://man7.org/linux/man-pages/man7/capabilities.7.html>.
   285	
   286	        let had_root = old_ruid.is_root() || old_euid.is_root() || old_suid.is_root();
   287	        let all_nonroot = !new_ruid.is_root() && !new_euid.is_root() && !new_suid.is_root();
   288	        if had_root && all_nonroot && !self.keep_capabilities() {
   289	            self.set_permitted_capset(CapSet::empty());
   290	            // TODO: Clear ambient capabilities when we support it. Note that ambient capabilities
   291	            // should be cleared even if `keep_capabilities` is true.
   292	        }
   293	
   294	        if old_euid.is_root() && !new_euid.is_root() {
   295	            self.set_effective_capset(CapSet::empty());
   296	        } else if !old_euid.is_root() && new_euid.is_root() {
   297	            let permitted = self.permitted_capset();
   298	            self.set_effective_capset(permitted);
   299	        }
   300	    }
   301	
   302	    fn set_fsuid_unchecked(&self, fsuid: Uid) {
   303	        let old_fsuid = self.fsuid();
   304	        self.fsuid.store(fsuid, Ordering::Relaxed);
   305	
   306	        if old_fsuid.is_root() && !fsuid.is_root() {
   307	            // Reference: The "Effect of user ID changes on capabilities" section in
   308	            // <https://man7.org/linux/man-pages/man7/capabilities.7.html>.
   309	            let cap_to_remove = CapSet::CHOWN
   310	                | CapSet::DAC_OVERRIDE
   311	                | CapSet::FOWNER
   312	                | CapSet::DAC_READ_SEARCH
   313	                | CapSet::FSETID
   314	                | CapSet::LINUX_IMMUTABLE
   315	                | CapSet::MAC_OVERRIDE
   316	                | CapSet::MKNOD;
   317	            let old_cap = self.effective_capset();
   318	            self.set_effective_capset(old_cap - cap_to_remove);
   319	        }
   320	    }

   653	impl Clone for Credentials_ {
   654	    fn clone(&self) -> Self {
   655	        Self {
   656	            ruid: self.ruid.clone(),
   657	            euid: self.euid.clone(),
   658	            suid: self.suid.clone(),
   659	            fsuid: self.fsuid.clone(),
   660	            rgid: self.rgid.clone(),
   661	            egid: self.egid.clone(),
   662	            sgid: self.sgid.clone(),
   663	            fsgid: self.fsgid.clone(),
   664	            supplementary_gids: RwLock::new(self.supplementary_gids.read().clone()),
   665	            inheritable_capset: self.inheritable_capset.clone(),
   666	            permitted_capset: self.permitted_capset.clone(),
   667	            effective_capset: self.effective_capset.clone(),
   668	            bounding_capset: self.bounding_capset.clone(),
   669	            securebits: self.securebits.clone(),
   670	        }
   671	    }
   672	}

